API_ENV={{ api_env }}
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg://{{ db_username }}:{{ db_password }}@{{ db_host }}:{{ db_port }}/{{ db_name }}
CHROMA_HOST=chromadb
CHROMA_PORT={{ chroma_port }}
CHROMA_COLLECTION={{ chroma_collection }}
UPLOAD_DIR=/app/data/uploads
STORAGE_BACKEND={{ storage_backend }}
S3_UPLOADS_BUCKET={{ s3_uploads_bucket }}
AWS_REGION={{ aws_region }}
AWS_DEFAULT_REGION={{ aws_region }}
WEB_APP_URL={{ web_app_url }}
API_CORS_ALLOW_ORIGINS={{ cors_origins | to_json }}
GOOGLE_OAUTH_CLIENT_ID={{ google_oauth_client_id }}
GOOGLE_OAUTH_CLIENT_SECRET={{ google_oauth_client_secret }}
INTEGRATION_OAUTH_STATE_SECRET={{ oauth_state_secret }}
SECRET_ENCRYPTION_KEY={{ secret_encryption_key }}
WORKER_INLINE_EXECUTION={{ worker_inline_execution }}
WORKER_POLL_INTERVAL_SECONDS={{ worker_poll_interval_seconds }}
