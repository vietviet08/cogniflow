services:
  api:
    image: {{ ecr_repository_url }}:{{ api_image_tag | default('latest') }}
    container_name: notemesh-api
    restart: unless-stopped
    env_file:
      - ./.env
    ports:
      - "127.0.0.1:{{ api_port }}:8000"
    volumes:
      - ./data/uploads:/app/data/uploads
      - ./logs:/app/logs
    depends_on:
      chromadb:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/api/v1/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    networks:
      - notemesh-net

  worker:
    image: {{ ecr_repository_url }}:{{ api_image_tag | default('latest') }}
    container_name: notemesh-worker
    command: ["python", "-m", "app.workers.runtime"]
    restart: unless-stopped
    env_file:
      - ./.env
    volumes:
      - ./data/uploads:/app/data/uploads
      - ./logs:/app/logs
    depends_on:
      chromadb:
        condition: service_healthy
    networks:
      - notemesh-net

  chromadb:
    image: chromadb/chroma:1.0.20
    container_name: notemesh-chromadb
    restart: unless-stopped
    expose:
      - "{{ chroma_port }}"
    environment:
      IS_PERSISTENT: "TRUE"
      ANONYMIZED_TELEMETRY: "FALSE"
    volumes:
      - ./data/chromadb:/data
    healthcheck:
      test: ["CMD", "/usr/bin/bash", "-c", "</dev/tcp/127.0.0.1/{{ chroma_port }}"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 20s
    networks:
      - notemesh-net

  pgadmin:
    image: dpage/pgadmin4:8.14
    container_name: notemesh-pgadmin
    restart: unless-stopped
    env_file:
      - ./pgadmin.env
    ports:
      - "127.0.0.1:{{ pgadmin_listen_port }}:80"
    volumes:
      - ./data/pgadmin:/var/lib/pgadmin
      - ./pgadmin-servers.json:/pgadmin4/servers.json:ro
    depends_on:
      - api
    networks:
      - notemesh-net

networks:
  notemesh-net:
    driver: bridge
