# ─── Điền các giá trị thực vào đây ───────────────────────────────────────────
# Copy file này thành terraform.tfvars và điền thông tin thực
# KHÔNG commit terraform.tfvars lên git (đã có trong .gitignore)

aws_region   = "ap-southeast-1"
project_name = "notemesh"
environment  = "prod"
domain_name  = "catcosy.shop"

# EC2 Key Pair (tạo trước trên AWS Console → EC2 → Key Pairs)
key_pair_name = "notemesh-keypair"

# IP của bạn để SSH (chạy: curl ifconfig.me)
your_ip_cidr = "YOUR_IP/32"  # Ví dụ: "123.456.789.0/32"

# RDS Database
db_name     = "notemesh"
db_username = "notemesh_admin"
db_password = "CHANGE_ME_STRONG_PASSWORD_123!"  # Đổi thành password mạnh

# S3 bucket names (phải unique toàn cầu)
uploads_bucket_name = "notemesh-uploads-prod"
static_bucket_name  = "notemesh-static-prod"

# EC2 (Ubuntu 22.04 LTS - ap-southeast-1)
ami_id        = "ami-0df7a207adb9748c7"
ec2_instance_type = "t3.medium"
