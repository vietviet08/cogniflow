API_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/cogniflow
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=cogniflow-documents
UPLOAD_DIR=data/uploads

WEB_APP_URL=http://localhost:3000
API_CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

INTEGRATION_OAUTH_STATE_SECRET=replace-with-a-long-random-secret
SECRET_ENCRYPTION_KEY=replace-with-a-long-random-secret
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

WORKER_INLINE_EXECUTION=true
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_QUEUE_NAME=

INTELLIGENCE_AUTOSCHEDULE_ENABLED=true
INTELLIGENCE_AUTOSCHEDULE_INTERVAL_SECONDS=60
INTELLIGENCE_AUTOSCHEDULE_BATCH_SIZE=50
INTELLIGENCE_MONITORING_QUEUE_NAME=monitoring
INTELLIGENCE_DEFAULT_ALERT_THRESHOLD=medium

OPS_QUEUE_BACKLOG_WARNING_THRESHOLD=25
OPS_QUEUE_LAG_WARNING_SECONDS=300
OPS_JOB_FAILURE_RATE_WARNING=0.2
OPS_LATENCY_P95_WARNING_MS=5000
